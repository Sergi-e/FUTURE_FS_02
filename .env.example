# Copy to `.env` in the project root (or edit `.env` directly). Do not commit real secrets.
#
# For MongoDB Atlas, use a mongodb+srv:// URI (see README.md — MongoDB Atlas section).

# Atlas: mongodb+srv://… is fine unless you see querySrv ECONNREFUSED — then use the non-SRV mongodb://… string from Atlas (SRV toggle off).
MONGO_URI=mongodb://127.0.0.1:27017/leadrift
JWT_SECRET=change_this_to_a_long_random_string
PORT=5000
# Browser origin(s) for CORS. Comma-separated for multiple. Non-production always allows
# http://localhost:5173 and http://127.0.0.1:5173 as well (same app opened either way).
CLIENT_ORIGIN=http://localhost:5173
