# Copy to `.env` in the project root (or edit `.env` directly). Do not commit real secrets.
#
# For MongoDB Atlas, use a mongodb+srv:// URI (see README.md — MongoDB Atlas section).

MONGO_URI=mongodb://127.0.0.1:27017/leadrift
JWT_SECRET=change_this_to_a_long_random_string
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
